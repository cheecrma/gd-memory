# 이 파일을 .env 로 복사한 뒤 값을 채우세요.
# value only. No quotes, no spaces, no Korean, no comment on the same line.

# Supabase 대시보드 → Project Settings → API
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Kakao Developers → 내 애플리케이션 → 앱 키 → "JavaScript 키"
